<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light palette, tuned to Office "White" / "Colorful" light chrome. -->
    <SolidColorBrush x:Key="Theme.Background" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Theme.Foreground" Color="#FF201F1E" />
    <SolidColorBrush x:Key="Theme.MutedForeground" Color="#FF605E5C" />

    <SolidColorBrush x:Key="Theme.ControlBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Theme.ControlBackgroundHover" Color="#FFF3F2F1" />
    <SolidColorBrush x:Key="Theme.ControlBorder" Color="#FFC8C6C4" />

    <SolidColorBrush x:Key="Theme.SelectionBackground" Color="#FFCCE4F7" />

    <SolidColorBrush x:Key="Theme.ButtonBackground" Color="#FFF3F2F1" />
    <SolidColorBrush x:Key="Theme.ButtonHover" Color="#FFE1DFDD" />
    <SolidColorBrush x:Key="Theme.ButtonPressed" Color="#FFD2D0CE" />

    <SolidColorBrush x:Key="Theme.DisabledForeground" Color="#FFA19F9D" />

</ResourceDictionary>
