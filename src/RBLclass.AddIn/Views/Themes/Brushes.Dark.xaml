<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark palette, tuned to Office "Dark Gray" / "Black" chrome. -->
    <SolidColorBrush x:Key="Theme.Background" Color="#FF2B2B2B" />
    <SolidColorBrush x:Key="Theme.Foreground" Color="#FFF3F2F1" />
    <SolidColorBrush x:Key="Theme.MutedForeground" Color="#FFB8B8B8" />

    <SolidColorBrush x:Key="Theme.ControlBackground" Color="#FF3B3B3B" />
    <SolidColorBrush x:Key="Theme.ControlBackgroundHover" Color="#FF454545" />
    <SolidColorBrush x:Key="Theme.ControlBorder" Color="#FF5A5A5A" />

    <SolidColorBrush x:Key="Theme.SelectionBackground" Color="#FF0E5A8A" />

    <SolidColorBrush x:Key="Theme.ButtonBackground" Color="#FF3B3B3B" />
    <SolidColorBrush x:Key="Theme.ButtonHover" Color="#FF4A4A4A" />
    <SolidColorBrush x:Key="Theme.ButtonPressed" Color="#FF565656" />

    <SolidColorBrush x:Key="Theme.DisabledForeground" Color="#FF7A7A7A" />

    <SolidColorBrush x:Key="Theme.AccentBackground" Color="#FF2899F5" />
    <SolidColorBrush x:Key="Theme.AccentForeground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Theme.AccentHover"      Color="#FF1A82D9" />
    <SolidColorBrush x:Key="Theme.AccentPressed"    Color="#FF1168B3" />

</ResourceDictionary>
