<Window x:Class="RBLclass.AddIn.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:RBLclass.AddIn.Localization"
        Title="{loc:Loc Key=About_Title}" Height="280" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        d:DesignHeight="280" d:DesignWidth="400">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock FontWeight="Bold" Text="{loc:Loc Key=About_Version_Label}" Margin="0,0,6,0" />
            <TextBlock x:Name="VersionText" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock FontWeight="Bold" Text="{loc:Loc Key=About_Author_Label}" Margin="0,0,6,0" />
            <TextBlock Text="{loc:Loc Key=About_Author_Text}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,4">
            <TextBlock FontWeight="Bold" Text="{loc:Loc Key=About_Tech_Label}" Margin="0,0,0,4" />
            <TextBlock Text="{loc:Loc Key=About_Tech_Text}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Easter egg: invisible trigger in the bottom-left corner. -->
        <Border Grid.Row="4" Width="10" Height="10"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="Arrow"
                MouseLeftButtonDown="EasterEgg_Click" />

        <Button Grid.Row="5" Content="{loc:Loc Key=About_Close_Button}"
                Click="Close_Click" HorizontalAlignment="Right"
                Padding="18,4" IsCancel="True" IsDefault="True" />
    </Grid>
</Window>
