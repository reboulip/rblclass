<UserControl x:Class="RBLclass.AddIn.Views.MainPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:v="clr-namespace:RBLclass.AddIn.Views"
             d:DesignHeight="520" d:DesignWidth="320">
    <Grid>
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
        </Grid.Resources>

        <!-- Disabled while a classify runs (re-entrancy guard). -->
        <Grid Margin="8" IsEnabled="{Binding IsNotBusy}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,0,0,6" FontWeight="Bold"
                       Text="{Binding SelectionSummary}" />

            <TextBox Grid.Row="1" x:Name="QueryBox" Margin="0,0,0,6"
                     Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="QueryBox_KeyDown"
                     PreviewKeyDown="QueryBox_PreviewKeyDown"
                     KeyUp="QueryBox_KeyUp"
                     PreviewMouseLeftButtonDown="QueryBox_PreviewMouseLeftButtonDown"
                     GotKeyboardFocus="QueryBox_GotKeyboardFocus"
                     ToolTip="Press Ctrl alone to toggle 'List every matching folder'" />

            <!-- Options. "Open folders in a new window" moved to Settings (v2.2). -->
            <StackPanel Grid.Row="2" Margin="0,0,0,6">
                <CheckBox Content="List every matching folder" IsChecked="{Binding AllResults}" />
                <CheckBox Content="Keep a copy (don't delete originals)" Margin="0,3,0,0" IsChecked="{Binding KeepCopy}" />
                <CheckBox Content="Remove attachments from the filed copy" Margin="0,3,0,0" IsChecked="{Binding RemoveAttachments}" />
                <CheckBox Content="Include the whole conversation" Margin="0,3,0,0" IsChecked="{Binding WidenConversation}" />
            </StackPanel>

            <!-- The shared list. Single-click toggles a folder as a destination;
                 double-click files into that one folder; the per-row buttons open
                 the folder in Outlook or create a sub-folder under it. -->
            <ListBox Grid.Row="3" x:Name="ResultsList"
                     ItemsSource="{Binding Results}"
                     SelectedItem="{Binding SelectedResult}"
                     HorizontalContentAlignment="Stretch"
                     MouseDoubleClick="ResultsList_MouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="↗" Width="22" Padding="0"
                                    Click="OpenFolder_Click" ToolTip="Open this folder in Outlook" />
                            <Button DockPanel.Dock="Right" Content="+" Width="22" Padding="0" Margin="0,0,3,0"
                                    Click="NewSubfolder_Click" ToolTip="Create a sub-folder here" />
                            <CheckBox IsChecked="{Binding IsSelected}"
                                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                                <TextBlock v:PathTrim.FullPath="{Binding DisplayPath}"
                                           v:PathTrim.RightReserve="52" />
                            </CheckBox>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Destinations accumulated across searches (v2.2): removable
                 chips; survives re-searches; clears after a classify. -->
            <StackPanel Grid.Row="4" Margin="0,6,0,0"
                        Visibility="{Binding HasSelectedDestinations, Converter={StaticResource BoolToVis}}">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="{Binding SelectionHeader}" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right" Content="clear" Padding="6,0"
                            Click="ClearSelection_Click"
                            ToolTip="Drop all selected destinations" />
                </DockPanel>
                <ItemsControl ItemsSource="{Binding SelectedDestinations}" Margin="0,3,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource Theme.SelectionBackground}"
                                    BorderBrush="{DynamicResource Theme.ControlBorder}"
                                    BorderThickness="1" CornerRadius="9"
                                    Padding="6,1" Margin="0,0,4,4"
                                    ToolTip="{Binding FullPath}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    <Button Content="✕" Margin="4,0,0,0" Padding="2,0"
                                            BorderThickness="0" Background="Transparent"
                                            Click="RemoveDestination_Click"
                                            ToolTip="Remove this destination" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Button Grid.Row="5" Margin="0,8,0,0" Padding="12,4" HorizontalAlignment="Left"
                    Content="{Binding ClassifyButtonText}" Click="Classify_Click" />

            <TextBlock Grid.Row="6" Margin="0,6,0,0" Style="{DynamicResource MutedText}"
                       Text="{Binding Status}" TextWrapping="Wrap" />
        </Grid>

        <!-- Busy overlay. -->
        <Border Background="{DynamicResource Theme.Background}" Opacity="0.85"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Filing…" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
