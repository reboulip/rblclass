    </UserControl.Resources>
    <Grid>
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <v:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        </Grid.Resources>

        <!-- Disabled while a classify runs (re-entrancy guard). -->
        <Grid Margin="8" IsEnabled="{Binding IsNotBusy}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 0: header -->
                <RowDefinition Height="Auto" />  <!-- 1: query box -->
                <RowDefinition Height="*" />     <!-- 2: results list -->
                <RowDefinition Height="Auto" />  <!-- 3: chip strip -->
                <RowDefinition Height="Auto" />  <!-- 4: Options toggle -->
                <RowDefinition Height="Auto" />  <!-- 5: Options panel -->
                <RowDefinition Height="Auto" />  <!-- 6: classify + undo -->
                <RowDefinition Height="Auto" />  <!-- 7: status -->
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,6">
                <!-- E1: prominent, width-adapting banner for a pinned just-sent mail. -->
                <Border Background="#0078D4" CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                        Visibility="{Binding HasPinnedItem, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Foreground="White" FontWeight="Bold" TextWrapping="Wrap"
                                   Text="{loc:Loc Key=MainPane_PinnedSentMail_Indicator}" />
                        <TextBlock Foreground="White" FontStyle="Italic" TextWrapping="Wrap" Margin="0,3,0,0"
                                   Text="{Binding PinnedItemSubject}" />
                    </StackPanel>
                </Border>
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left" FontWeight="Bold" VerticalAlignment="Center"
                               Text="{Binding SelectionSummary}" />
                    <Button DockPanel.Dock="Right" Padding="6,1"
                            IsEnabled="{Binding CanAutoClass}" Click="AutoClass_Click"
                            ToolTip="{loc:Loc Key=MainPane_AutoClass_ToolTip}">
                        <Button.Content>
                            <Grid>
                                <TextBlock Text="{Binding AutoClassLabel}" FontSize="11"
                                           Visibility="{Binding IsEasterEggActive, Converter={StaticResource InverseBoolToVis}}" />
                                <Image Width="26" Height="26" Source="{StaticResource PigDrawingImage}"
                                       Visibility="{Binding IsEasterEggActive, Converter={StaticResource BoolToVis}}" />
                            </Grid>
                        </Button.Content>
                    </Button>
                    <Ellipse DockPanel.Dock="Right" Width="10" Height="10" Margin="0,0,6,0"
                             VerticalAlignment="Center" ToolTip="{Binding IndexStatusToolTip}">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#D13438" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IndexStatus}" Value="{x:Static core:IndexStatus.Indexing}">
                                        <Setter Property="Fill" Value="#F2C811" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IndexStatus}" Value="{x:Static core:IndexStatus.Ready}">
                                        <Setter Property="Fill" Value="#3FA34D" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </DockPanel>
            </StackPanel>

            <TextBox Grid.Row="1" x:Name="QueryBox" Margin="0,0,0,6"
                     Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="QueryBox_KeyDown"
                     PreviewKeyDown="QueryBox_PreviewKeyDown"
                     KeyUp="QueryBox_KeyUp"
                     ToolTip="{loc:Loc Key=MainPane_QueryBox_ToolTip}" />

            <!-- The shared list. Single-click toggles a folder as a destination;
                 double-click files into that one folder; the ↗ button opens the
                 folder in Outlook, the ⤢ button expands that one row to a
                 multi-line full path, and right-click adds a sub-folder. -->
            <ListBox Grid.Row="2" x:Name="ResultsList"
                     ItemsSource="{Binding Results}"
                     SelectedItem="{Binding SelectedResult}"
                     HorizontalContentAlignment="Stretch"
                     MouseDoubleClick="ResultsList_MouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel LastChildFill="True">
                            <DockPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{loc:Loc Key=MainPane_NewSubfolder_MenuItem}"
                                              Click="NewSubfolder_Click" />
                                </ContextMenu>
                            </DockPanel.ContextMenu>
                            <Button DockPanel.Dock="Right" Content="↗" Width="22" Padding="0" VerticalAlignment="Top"
                                    Click="OpenFolder_Click" ToolTip="{loc:Loc Key=MainPane_OpenFolder_ToolTip}" />
                            <Button DockPanel.Dock="Right" Content="⤢" Width="22" Padding="0" Margin="0,0,3,0" VerticalAlignment="Top"
                                    Click="ExpandPath_Click"
                                    ToolTip="{loc:Loc Key=MainPane_ExpandPath_ToolTip}" />
                            <CheckBox IsChecked="{Binding IsSelected}"
                                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                                <Grid>
                                    <!-- Collapsed: single left-trimmed line. -->
                                    <TextBlock v:PathTrim.FullPath="{Binding DisplayPath}"
                                               v:PathTrim.RightReserve="52"
                                               Visibility="{Binding IsExpanded, Converter={StaticResource InverseBoolToVis}}" />
                                    <!-- Expanded: full path, one segment per line, no indentation. -->
                                    <ItemsControl ItemsSource="{Binding PathSegments}"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </CheckBox>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Destinations accumulated across searches (v2.2): removable
                 chips; survives re-searches; clears after a classify. -->
            <StackPanel Grid.Row="3" Margin="0,6,0,0"
                        Visibility="{Binding HasSelectedDestinations, Converter={StaticResource BoolToVis}}">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="{Binding SelectionHeader}" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right" Content="{loc:Loc Key=MainPane_ClearSelection_Button}" Padding="6,0"
                            Click="ClearSelection_Click"
                            ToolTip="{loc:Loc Key=MainPane_ClearSelection_ToolTip}" />
                </DockPanel>
                <ItemsControl ItemsSource="{Binding SelectedDestinations}" Margin="0,3,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource Theme.SelectionBackground}"
                                    BorderBrush="{DynamicResource Theme.ControlBorder}"
                                    BorderThickness="1" CornerRadius="9"
                                    Padding="6,1" Margin="0,0,4,4"
                                    ToolTip="{Binding FullPath}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    <Button Content="✕" Margin="4,0,0,0" Padding="2,0"
                                            BorderThickness="0" Background="Transparent"
                                            Click="RemoveDestination_Click"
                                            ToolTip="{loc:Loc Key=MainPane_RemoveDestination_ToolTip}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Options toggle: always visible, low-profile; shows/hides the panel (v2.4 B1). -->
            <Button Grid.Row="4" x:Name="OptionsToggle"
                    Content="{loc:Loc Key=Pane_Options}"
                    HorizontalAlignment="Left" Padding="4,2" Margin="0,4,0,0" FontSize="11"
                    Click="Options_Click" />

            <!-- Options panel: collapsed by default; opened by the toggle or Tab from the query box. -->
            <StackPanel Grid.Row="5" x:Name="OptionsPanel" Margin="0,4,0,0"
                        Visibility="{Binding IsOptionsExpanded, Converter={StaticResource BoolToVis}}">
                <CheckBox x:Name="FirstOptionCheckBox"
                          Content="{loc:Loc Key=MainPane_ListEveryFolder_CheckBox}" IsChecked="{Binding AllResults}" />
                <CheckBox Content="{loc:Loc Key=MainPane_KeepCopy_CheckBox}" Margin="0,3,0,0" IsChecked="{Binding KeepCopy}" />
                <CheckBox Content="{loc:Loc Key=MainPane_RemoveAttachments_CheckBox}" Margin="0,3,0,0" IsChecked="{Binding RemoveAttachments}" />
                <CheckBox Content="{loc:Loc Key=MainPane_WidenConversation_CheckBox}" Margin="0,3,0,0" IsChecked="{Binding WidenConversation}" />
                <CheckBox Content="{loc:Loc Key=MainPane_StripBanner_CheckBox}" Margin="0,3,0,0"
                          IsChecked="{Binding StripBanner}"
                          Visibility="{Binding CanStripBanner, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Padding="12,4" Content="{Binding ClassifyButtonText}" Click="Classify_Click" />
                <Button Padding="12,4" Margin="6,0,0,0" Content="{loc:Loc Key=MainPane_Undo_Button}"
                        IsEnabled="{Binding CanUndo}" Click="Undo_Click"
                        ToolTip="{loc:Loc Key=MainPane_Undo_ToolTip}" />
            </StackPanel>

            <!-- Row 7: live search feedback (single self-superseding line) above a
                 collapsible rolling journal of action outcomes, newest first,
                 collapsed by default and toggled like the Options zone (v2.5.0.0 A1). -->
            <StackPanel Grid.Row="7" Margin="0,6,0,0">
                <TextBlock Style="{DynamicResource MutedText}" TextWrapping="Wrap"
                           Text="{Binding SearchFeedback}" />
                <Button x:Name="JournalToggle" Content="{loc:Loc Key=Pane_Journal}"
                        HorizontalAlignment="Left" Padding="4,2" Margin="0,4,0,0" FontSize="11"
                        Click="Journal_Click"
                        Visibility="{Binding HasStatusEntries, Converter={StaticResource BoolToVis}}" />
                <ItemsControl Margin="0,2,0,0" ItemsSource="{Binding StatusLog}"
                              Visibility="{Binding IsStatusLogExpanded, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Style="{DynamicResource MutedText}" TextWrapping="Wrap"
                                       Text="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- Busy overlay. -->
        <Border Background="{DynamicResource Theme.Background}" Opacity="0.85"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding BusyStatus}" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
