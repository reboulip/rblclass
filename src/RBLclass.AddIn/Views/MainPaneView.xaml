<UserControl x:Class="RBLclass.AddIn.Views.MainPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:v="clr-namespace:RBLclass.AddIn.Views"
             xmlns:loc="clr-namespace:RBLclass.AddIn.Localization"
             xmlns:core="clr-namespace:RBLclass.Core;assembly=RBLclass.Core"
             d:DesignHeight="520" d:DesignWidth="320">
    <UserControl.Resources>
