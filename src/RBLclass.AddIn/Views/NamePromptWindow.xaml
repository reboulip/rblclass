<Window x:Class="RBLclass.AddIn.Views.NamePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:RBLclass.AddIn.Localization"
        Title="{loc:Loc Key=NamePrompt_Title}" Height="160" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        d:DesignHeight="160" d:DesignWidth="360">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="PromptLabel" TextWrapping="Wrap"
                   Text="{loc:Loc Key=NamePrompt_Label}" />

        <TextBox Grid.Row="1" x:Name="NameBox" Margin="0,8,0,0"
                 KeyDown="NameBox_KeyDown" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{loc:Loc Key=NamePrompt_Create_Button}" Click="Ok_Click" Margin="0,0,8,0" Padding="14,3" IsDefault="True" />
            <Button Content="{loc:Loc Key=NamePrompt_Cancel_Button}" Click="Cancel_Click" Padding="14,3" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
