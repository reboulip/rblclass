<Window x:Class="RBLclass.AddIn.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="RBLclass - Settings" Height="640" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        d:DesignHeight="640" d:DesignWidth="480">
    <DockPanel Margin="12">
        <Button DockPanel.Dock="Bottom" Content="Close" Click="Close_Click"
                HorizontalAlignment="Right" Margin="0,12,0,0"
                Padding="18,4" IsCancel="True" IsDefault="True" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Folder search" Margin="0,0,0,8">
                    <StackPanel Margin="6">
                        <CheckBox Margin="0,3" IsChecked="{Binding AllResults}"
                                  Content="List every matching folder individually" />
                        <CheckBox Margin="0,3" IsChecked="{Binding UseWordPrefixMatch}">
                            <TextBlock TextWrapping="Wrap" MaxWidth="400"
                                       Text="Match only the start of words (stricter than the default 'contains' search)" />
                        </CheckBox>
                        <CheckBox Margin="0,3" IsChecked="{Binding OpenInNewWindow}"
                                  Content="Open folders in a new explorer window" />
                        <DockPanel Margin="0,8,0,2" LastChildFill="False">
                            <TextBlock Text="Maximum results to display:" VerticalAlignment="Center" />
                            <TextBox DockPanel.Dock="Right" Width="60" Margin="6,0,0,0"
                                     Text="{Binding MaxResultsText, UpdateSourceTrigger=LostFocus}" />
                        </DockPanel>
                        <DockPanel Margin="0,4,0,2" LastChildFill="False">
                            <TextBlock Text="Search after typing at least (characters):" VerticalAlignment="Center" />
                            <TextBox DockPanel.Dock="Right" Width="60" Margin="6,0,0,0"
                                     Text="{Binding MinSearchLengthText, UpdateSourceTrigger=LostFocus}" />
                        </DockPanel>
                        <DockPanel Margin="0,4,0,2" LastChildFill="False">
                            <TextBlock Text="Pause before searching (milliseconds):" VerticalAlignment="Center" />
                            <TextBox DockPanel.Dock="Right" Width="60" Margin="6,0,0,0"
                                     Text="{Binding SearchDebounceMsText, UpdateSourceTrigger=LostFocus}" />
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Classify" Margin="0,0,0,8">
                    <StackPanel Margin="6">
                        <CheckBox Margin="0,3" IsChecked="{Binding KeepCopy}"
                                  Content="Keep the original after classifying" />
                        <CheckBox Margin="0,3" IsChecked="{Binding RemoveAttachments}"
                                  Content="Remove attachments from the filed copy" />
                        <CheckBox Margin="0,3" IsChecked="{Binding ClassifySafetyCopy}">
                            <TextBlock TextWrapping="Wrap" MaxWidth="400"
                                       Text="Keep a safety copy in Deleted Items when filing (only applies when the original is not kept)" />
                        </CheckBox>
                        <CheckBox Margin="0,3" IsChecked="{Binding WidenConversation}"
                                  Content="Apply to the whole conversation by default" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Sending guards" Margin="0,0,0,8">
                    <StackPanel Margin="6">
                        <CheckBox Margin="0,3" IsChecked="{Binding SendExternalWarning}">
                            <TextBlock TextWrapping="Wrap" MaxWidth="400"
                                       Text="Warn before sending to recipients outside the organisation" />
                        </CheckBox>
                        <TextBlock Margin="0,8,0,2" Text="Domains treated as internal (semicolon-separated):" />
                        <TextBox Text="{Binding InternalDomainsText, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Margin="0,8,0,2" Text="Forgotten-attachment keywords (semicolon-separated):" />
                        <TextBox Text="{Binding ForgottenAttachmentKeywordsText, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Sent items">
                    <StackPanel Margin="6">
                        <TextBlock Text="When a mail lands in Sent Items:" />
                        <ComboBox Margin="0,4,0,0" Width="220" HorizontalAlignment="Left"
                                  ItemsSource="{Binding TriageModes}"
                                  SelectedValuePath="Mode"
                                  SelectedValue="{Binding SentItemTriageMode}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
