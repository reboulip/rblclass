<Window x:Class="RBLclass.AddIn.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:RBLclass.AddIn.Localization"
        Title="{loc:Loc Key=Settings_Title}" Height="640" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        d:DesignHeight="640" d:DesignWidth="480">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <DockPanel Margin="12">
        <Button DockPanel.Dock="Bottom" Content="{loc:Loc Key=Settings_Close_Button}" Click="Close_Click"
                HorizontalAlignment="Right" Margin="0,12,0,0"
                Padding="18,4" IsCancel="True" IsDefault="True" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="{loc:Loc Key=Settings_FolderSearch_Header}" Margin="0,0,0,8">
                    <StackPanel Margin="6">
                        <CheckBox Margin="0,3" IsChecked="{Binding AllResults}"
                                  Content="{loc:Loc Key=Settings_ListEveryFolder_CheckBox}" />
                        <CheckBox Margin="0,3" IsChecked="{Binding UseWordPrefixMatch}">
                            <TextBlock TextWrapping="Wrap" MaxWidth="400"
                                       Text="{loc:Loc Key=Settings_WordPrefixMatch_CheckBox}" />
                        </CheckBox>
                        <CheckBox Margin="0,3" IsChecked="{Binding OpenInNewWindow}"
                                  Content="{loc:Loc Key=Settings_OpenInNewWindow_CheckBox}" />
                        <CheckBox Margin="0,3" IsChecked="{Binding AutoExpandResults}"
                                  Content="{loc:Loc Key=Settings_AutoExpand_CheckBox}" />
                        <DockPanel Margin="0,8,0,2" LastChildFill="False">
                            <TextBlock Text="{loc:Loc Key=Settings_MaxResults_Label}" VerticalAlignment="Center" />
                            <TextBox DockPanel.Dock="Right" Width="60" Margin="6,0,0,0"
                                     Text="{Binding MaxResultsText, UpdateSourceTrigger=LostFocus}" />
                        </DockPanel>
                        <DockPanel Margin="0,4,0,2" LastChildFill="False">
                            <TextBlock Text="{loc:Loc Key=Settings_MinSearchLength_Label}" VerticalAlignment="Center" />
                            <TextBox DockPanel.Dock="Right" Width="60" Margin="6,0,0,0"
                                     Text="{Binding MinSearchLengthText, UpdateSourceTrigger=LostFocus}" />
                        </DockPanel>
                        <DockPanel Margin="0,4,0,2" LastChildFill="False">
                            <TextBlock Text="{loc:Loc Key=Settings_SearchDebounce_Label}" VerticalAlignment="Center" />
                            <TextBox DockPanel.Dock="Right" Width="60" Margin="6,0,0,0"
                                     Text="{Binding SearchDebounceMsText, UpdateSourceTrigger=LostFocus}" />
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:Loc Key=Settings_Classify_Header}" Margin="0,0,0,8">
                    <StackPanel Margin="6">
                        <CheckBox Margin="0,3" IsChecked="{Binding KeepCopy}"
                                  Content="{loc:Loc Key=Settings_KeepCopy_CheckBox}" />
                        <CheckBox Margin="0,3" IsChecked="{Binding RemoveAttachments}"
                                  Content="{loc:Loc Key=Settings_RemoveAttachments_CheckBox}" />
                        <StackPanel Margin="18,0,0,3">
                            <TextBlock Margin="0,2,0,0" FontStyle="Italic" Foreground="#777"
                                       Text="{loc:Loc Key=Settings_AttachmentRemovalMode_Label}" />
                            <RadioButton Margin="0,2" GroupName="AttachMode"
                                         IsChecked="{Binding AttachmentRemovalModeIsModal}">
                                <TextBlock TextWrapping="Wrap" MaxWidth="380"
                                           Text="{loc:Loc Key=Settings_AttachmentRemovalMode_Modal}" />
                            </RadioButton>
                            <RadioButton Margin="0,2" GroupName="AttachMode"
                                         IsChecked="{Binding AttachmentRemovalModeIsDeleteSilently}">
                                <TextBlock TextWrapping="Wrap" MaxWidth="380"
                                           Text="{loc:Loc Key=Settings_AttachmentRemovalMode_DeleteSilently}" />
                            </RadioButton>
                            <TextBlock Margin="0,6,0,0" FontStyle="Italic" Foreground="#777"
                                       Text="{loc:Loc Key=Settings_AttachmentLabelLocation_Label}" />
                            <RadioButton Margin="0,2" GroupName="AttachLabelLoc"
                                         IsChecked="{Binding AttachmentLabelLocationIsBody}">
                                <TextBlock TextWrapping="Wrap" MaxWidth="380"
                                           Text="{loc:Loc Key=Settings_AttachmentLabelLocation_Body}" />
                            </RadioButton>
                            <RadioButton Margin="0,2" GroupName="AttachLabelLoc"
                                         IsChecked="{Binding AttachmentLabelLocationIsInfoBar}">
                                <TextBlock TextWrapping="Wrap" MaxWidth="380"
                                           Text="{loc:Loc Key=Settings_AttachmentLabelLocation_InfoBar}" />
                            </RadioButton>
                            <RadioButton Margin="0,2" GroupName="AttachLabelLoc"
                                         IsChecked="{Binding AttachmentLabelLocationIsNone}">
                                <TextBlock TextWrapping="Wrap" MaxWidth="380"
                                           Text="{loc:Loc Key=Settings_AttachmentLabelLocation_None}" />
                            </RadioButton>
                        </StackPanel>
                        <CheckBox Margin="0,3" IsChecked="{Binding ClassifySafetyCopy}">
                            <TextBlock TextWrapping="Wrap" MaxWidth="400"
                                       Text="{loc:Loc Key=Settings_ClassifySafetyCopy_CheckBox}" />
                        </CheckBox>
                        <CheckBox Margin="0,3" IsChecked="{Binding WidenConversation}"
                                  Content="{loc:Loc Key=Settings_WidenConversation_CheckBox}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:Loc Key=Settings_Banner_Header}" Margin="0,0,0,8">
                    <StackPanel Margin="6">
                        <TextBlock TextWrapping="Wrap" Style="{DynamicResource MutedText}"
                                   Text="{loc:Loc Key=Settings_Banner_Description}" />
                        <DockPanel Margin="0,6,0,2" LastChildFill="False">
                            <Button DockPanel.Dock="Left" Content="{loc:Loc Key=Settings_LearnBanner_Button}" Padding="8,2"
                                    IsEnabled="{Binding CanLearnBanner}" Click="LearnBanner_Click" />
                            <Button DockPanel.Dock="Left" Content="{loc:Loc Key=Settings_ForgetBanner_Button}" Padding="8,2" Margin="6,0,0,0"
                                    IsEnabled="{Binding HasBanner}" Click="ClearBanner_Click" />
                        </DockPanel>
                        <TextBlock Margin="0,2,0,4" TextWrapping="Wrap"
                                   Style="{DynamicResource MutedText}" Text="{Binding BannerStatus}" />
                        <CheckBox Margin="0,3" IsChecked="{Binding StripBannerOnReply}"
                                  IsEnabled="{Binding HasBanner}"
                                  Content="{loc:Loc Key=Settings_StripBannerOnReply_CheckBox}" />
                        <CheckBox Margin="0,3" IsChecked="{Binding StripBannerOnClassify}"
                                  IsEnabled="{Binding HasBanner}">
                            <TextBlock TextWrapping="Wrap" MaxWidth="400"
                                       Text="{loc:Loc Key=Settings_StripBannerOnClassify_CheckBox}" />
                        </CheckBox>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:Loc Key=Settings_SendingGuards_Header}" Margin="0,0,0,8">
                    <StackPanel Margin="6">
                        <CheckBox Margin="0,3" IsChecked="{Binding SendExternalWarning}">
                            <TextBlock TextWrapping="Wrap" MaxWidth="400"
                                       Text="{loc:Loc Key=Settings_SendExternalWarning_CheckBox}" />
                        </CheckBox>
                        <TextBlock Margin="0,8,0,2" Text="{loc:Loc Key=Settings_InternalDomains_Label}" />
                        <TextBox Text="{Binding InternalDomainsText, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock Margin="0,8,0,2" Text="{loc:Loc Key=Settings_ForgottenAttachmentKeywords_Label}" />
                        <TextBox Text="{Binding ForgottenAttachmentKeywordsText, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:Loc Key=Settings_SentItems_Header}" Margin="0,0,0,8">
                    <StackPanel Margin="6">
                        <TextBlock Text="{loc:Loc Key=Settings_SentItemsTriage_Label}" />
                        <ComboBox Margin="0,4,0,0" Width="220" HorizontalAlignment="Left"
                                  ItemsSource="{Binding TriageModes}"
                                  SelectedValuePath="Mode"
                                  SelectedValue="{Binding SentItemTriageMode}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <CheckBox Margin="0,8,0,0" IsChecked="{Binding ClassifyAfterMoveToInbox}">
                            <TextBlock TextWrapping="Wrap" MaxWidth="400"
                                       Text="{loc:Loc Key=Settings_ClassifyAfterMoveToInbox_CheckBox}" />
                        </CheckBox>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:Loc Key=Settings_FavoriteFolders_Header}" Margin="0,0,0,8">
                    <StackPanel Margin="6">
                        <TextBlock TextWrapping="Wrap"
                                   Text="{loc:Loc Key=Settings_FavoriteFolders_Description}" />
                        <ListBox x:Name="FavoriteFoldersList" Margin="0,6,0,4" Height="96"
                                 ItemsSource="{Binding FavoriteFolders}" />
                        <DockPanel LastChildFill="False">
                            <Button DockPanel.Dock="Left" Padding="8,2"
                                    Content="{loc:Loc Key=Settings_FavoriteFolders_Add_Button}"
                                    Click="AddFavoriteFolder_Click" />
                            <Button DockPanel.Dock="Left" Padding="8,2" Margin="6,0,0,0"
                                    Content="{loc:Loc Key=Settings_FavoriteFolders_Remove_Button}"
                                    Click="RemoveFavoriteFolder_Click" />
                        </DockPanel>
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="{loc:Loc Key=Settings_FavoriteFolders_Note}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{loc:Loc Key=Settings_Language_Header}">
                    <StackPanel Margin="6">
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="{loc:Loc Key=Settings_Language_Label}" VerticalAlignment="Center" />
                            <ComboBox DockPanel.Dock="Right" Width="180" HorizontalAlignment="Right"
                                      ItemsSource="{Binding UiLanguages}"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding PreferredUiLanguage}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DockPanel>
                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap"
                                   Style="{DynamicResource MutedText}"
                                   Text="{loc:Loc Key=Settings_Language_RestartNote}" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
