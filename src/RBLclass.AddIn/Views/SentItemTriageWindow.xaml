<Window x:Class="RBLclass.AddIn.Views.SentItemTriageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="RBLclass - Sent mail" Height="180" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        d:DesignHeight="180" d:DesignWidth="380">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontWeight="Bold" TextWrapping="Wrap"
                   Text="What should RBLclass do with this mail?" />
        <TextBlock Grid.Row="1" Margin="0,4,0,8" Style="{DynamicResource MutedText}"
                   Text="{Binding Subject}" TextTrimming="CharacterEllipsis" />

        <UniformGrid Grid.Row="2" Columns="3" Rows="1" VerticalAlignment="Top">
            <Button Margin="4" Padding="8,6" Content="Move to Inbox" Command="{Binding MoveToInboxCommand}" />
            <Button Margin="4" Padding="8,6" Content="Delete" Command="{Binding DeleteCommand}" />
            <Button Margin="4" Padding="8,6" Content="Leave" Command="{Binding LeaveCommand}" />
        </UniformGrid>
    </Grid>
</Window>
