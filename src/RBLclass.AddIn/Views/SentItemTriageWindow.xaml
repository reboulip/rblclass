<Window x:Class="RBLclass.AddIn.Views.SentItemTriageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="RBLclass - Sent mail" Height="230" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        d:DesignHeight="230" d:DesignWidth="380">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontWeight="Bold" TextWrapping="Wrap"
                   Text="What should RBLclass do with this mail?" />
        <TextBlock Grid.Row="1" Margin="0,4,0,8" Style="{DynamicResource MutedText}"
                   Text="{Binding Subject}" TextTrimming="CharacterEllipsis" />

        <UniformGrid Grid.Row="2" Columns="2" Rows="2">
            <Button Margin="4" Padding="8,6" Content="Class…" Command="{Binding ClassCommand}" />
            <Button Margin="4" Padding="8,6" Content="Delete" Command="{Binding DeleteCommand}" />
            <Button Margin="4" Padding="8,6" Content="Move to Inbox" Command="{Binding MoveToInboxCommand}" />
            <Button Margin="4" Padding="8,6" Content="Leave" Command="{Binding LeaveCommand}" />
        </UniformGrid>

        <CheckBox Grid.Row="3" Margin="0,8,0,0" Content="Apply to the whole conversation"
                  IsChecked="{Binding WholeConversation}" />
    </Grid>
</Window>
