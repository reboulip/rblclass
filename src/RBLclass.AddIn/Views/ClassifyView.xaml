<UserControl x:Class="RBLclass.AddIn.Views.ClassifyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignHeight="460" d:DesignWidth="320">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,6" FontWeight="Bold"
                   Text="{Binding SelectionSummary}" />

        <TextBox Grid.Row="1" x:Name="QueryBox" Margin="0,0,0,6"
                 Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                 KeyDown="QueryBox_KeyDown" />

        <CheckBox Grid.Row="2" Margin="0,0,0,6" Content="All results"
                  IsChecked="{Binding AllResults}" />

        <!-- Destinations are toggled with single clicks via the per-row checkbox
             (no Ctrl needed). -->
        <ListBox Grid.Row="3" x:Name="ResultsList"
                 ItemsSource="{Binding Results}"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}"
                              Content="{Binding DisplayPath}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="4" Margin="0,6,0,0">
            <CheckBox Content="Keep a copy (don't delete originals)" IsChecked="{Binding KeepCopy}" />
            <CheckBox Content="Remove attachments" Margin="0,4,0,0" IsChecked="{Binding RemoveAttachments}" />
            <CheckBox Content="Include whole conversation" Margin="0,4,0,0" IsChecked="{Binding WidenConversation}" />
            <DockPanel Margin="0,6,0,0" LastChildFill="True">
                <Button DockPanel.Dock="Right" Margin="6,0,0,0" Padding="8,2"
                        Content="New subfolder" Click="NewSubfolder_Click"
                        ToolTip="Create a sub-folder under the highlighted folder" />
                <TextBox x:Name="NewFolderNameBox" />
            </DockPanel>
        </StackPanel>

        <Button Grid.Row="5" Margin="0,8,0,0" Padding="12,4" HorizontalAlignment="Left"
                Content="Classify selected mail" Click="Classify_Click" />

        <TextBlock Grid.Row="6" Margin="0,6,0,0" Style="{DynamicResource MutedText}"
                   Text="{Binding Status}" TextWrapping="Wrap" />
    </Grid>
</UserControl>
